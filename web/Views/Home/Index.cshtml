@model SteamHeatmap.Web.Domain.RegionMapViewModel
@{
    ViewData["Title"] = "Steam Regional Popularity Heatmap";
}

<h1>Steam Regional Popularity Heatmap</h1>

<aside class="disclosures">
    <p>
        Region data is <strong>inferred from the language of each game's Steam reviews</strong>,
        not from official Steam geographic data — Valve doesn't publish any. True per-country
        data could reveal finer differences that a shared review language (like English or
        Spanish) blurs together.
    </p>
    <p>
        SteamHeatmap is not affiliated with or endorsed by Valve. Data powered by
        <a href="https://store.steampowered.com/" target="_blank" rel="noopener">Steam</a>.
    </p>
</aside>

<div id="map"></div>

@foreach (var region in Model.Regions)
{
    <section class="region">
        <h2>
            @region.DisplayName
            @if (region.Blended)
            {
                <small>(blended: @string.Join(", ", region.MemberCountries))</small>
            }
        </h2>
        <ol>
            @foreach (var game in region.Games)
            {
                <li>
                    <a href="@game.StoreUrl" target="_blank" rel="noopener">@game.Name</a>
                    — concentration @game.Concentration.ToString("0.000", System.Globalization.CultureInfo.InvariantCulture)
                </li>
            }
        </ol>
    </section>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/d3@7"></script>
    <script>
        const regions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Regions.Select(r => new
            {
                code = r.Code,
                displayName = r.DisplayName,
                mapCountryCodes = r.MapCountryCodes,
                topGame = r.Games.FirstOrDefault()?.Name,
                topConcentration = r.Games.FirstOrDefault()?.Concentration ?? 0
            })));

        const regionByCountry = new Map();
        regions.forEach(region => {
            region.mapCountryCodes.forEach(code => regionByCountry.set(code, region));
        });

        const width = 960;
        const height = 500;
        const svg = d3.select("#map").append("svg")
            .attr("viewBox", `0 0 ${width} ${height}`);

        const color = d3.scaleSequential(d3.interpolateYlOrRd).domain([0, 2]);
        const noDataFill = "#e3e3e3";

        d3.json("/data/world-110m.geojson").then(world => {
            const projection = d3.geoNaturalEarth1().fitSize([width, height], world);
            const path = d3.geoPath(projection);

            svg.selectAll("path")
                .data(world.features)
                .join("path")
                .attr("d", path)
                .attr("fill", feature => {
                    const region = regionByCountry.get(feature.properties.iso_a2);
                    return region ? color(region.topConcentration) : noDataFill;
                })
                .attr("stroke", "#fff")
                .attr("stroke-width", 0.5)
                .append("title")
                .text(feature => {
                    const region = regionByCountry.get(feature.properties.iso_a2);
                    return region
                        ? `${feature.properties.name} — ${region.displayName}: ${region.topGame}`
                        : `${feature.properties.name} — no data yet`;
                });
        });
    </script>
}
