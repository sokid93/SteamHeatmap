@using System.Text.Json
@model SteamHeatmap.Web.Domain.RegionMapViewModel
@{
    ViewData["Title"] = "Steam Regional Popularity Heatmap";
}

<h1>Steam Regional Popularity Heatmap</h1>

<aside class="disclosures">
    <p>
        Region data is <strong>inferred from the language of each game's Steam reviews</strong>,
        not from official Steam geographic data — Valve doesn't publish any. True per-country
        data could reveal finer differences that a shared review language (like English or
        Spanish) blurs together.
    </p>
    <p>
        SteamHeatmap is not affiliated with or endorsed by Valve. Data powered by
        <a href="https://store.steampowered.com/" target="_blank" rel="noopener">Steam</a>.
    </p>
</aside>

<h2 id="map-headline" class="map-headline"></h2>

<div class="game-search">
    <input id="game-search-input" type="text" placeholder="Search a game…" autocomplete="off" />
    <div id="game-search-results"></div>
</div>

<div class="map-layout">
    <div id="map"></div>
    <aside id="region-panel">
        <p class="region-panel-hint">Click a region to see which games are disproportionately popular there.</p>
    </aside>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/d3@7"></script>
    <script src="~/js/map.js" asp-append-version="true"></script>
    <script>
        initRegionMap({
            regions: @Html.Raw(JsonSerializer.Serialize(
                Model.Regions, new JsonSerializerOptions(JsonSerializerDefaults.Web))),
            games: @Html.Raw(JsonSerializer.Serialize(
                Model.Games, new JsonSerializerOptions(JsonSerializerDefaults.Web))),
            featuredAppId: @Html.Raw(JsonSerializer.Serialize(Model.FeaturedAppId)),
            concentrationsByGame: @Html.Raw(JsonSerializer.Serialize(
                Model.ConcentrationsByGame, new JsonSerializerOptions(JsonSerializerDefaults.Web))),
            geojsonUrl: "/data/world-110m.geojson",
            mapElement: document.getElementById("map"),
            panelElement: document.getElementById("region-panel"),
            headlineElement: document.getElementById("map-headline"),
            searchInputElement: document.getElementById("game-search-input"),
            searchResultsElement: document.getElementById("game-search-results")
        });
    </script>
}
